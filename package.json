{
  "name": "nuvio",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r --filter \"!./packages/next\" --filter \"./packages/**\" run build",
    "typecheck": "pnpm -r --filter \"!./apps/next-dogfood\" run typecheck",
    "test": "pnpm -r run test",
    "dev": "pnpm build && pnpm --filter @nuvio/demo-app dev",
    "dev:tailadmin": "pnpm build && pnpm --filter @nuvio/tailadmin-dogfood dev",
    "dev:next": "pnpm build && pnpm --filter @nuvio/next-dogfood dev",
    "dogfood": "pnpm build && pnpm typecheck && pnpm test && pnpm --filter @nuvio/demo-app build",
    "dogfood:next": "pnpm --filter @nuvio/next-dogfood build",
    "v05:acceptance:beta": "node scripts/v05-beta-acceptance.mjs --url=http://localhost:5173",
    "v05:acceptance:stable": "node scripts/v05-stable-acceptance.mjs --url=http://localhost:5173 --demo-url=http://localhost:5174",
    "v05:acceptance": "pnpm v05:acceptance:beta && pnpm v05:acceptance:stable",
    "test:cli": "pnpm --filter @nuvio/cli test",
    "v051:acceptance": "node scripts/v051-cli-acceptance.mjs",
    "publish:alpha": "pnpm -r publish --filter \"./packages/*\" --access public --tag alpha",
    "publish:stable": "pnpm -r publish --filter \"./packages/*\" --access public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      }
    }
  }
}
