{
  "name": "@nuvio/next-dogfood",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @nuvio/shared run build && pnpm --filter @nuvio/ast-engine run build && pnpm --filter @nuvio/overlay run build && pnpm --filter @nuvio/vite-plugin run build && pnpm --filter @nuvio/next run build",
    "dev": "node server.js",
    "build": "next build",
    "start": "NODE_ENV=production node server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nuvio/next": "workspace:*",
    "@nuvio/overlay": "workspace:*",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.8",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "postcss": "^8.5.2",
    "tailwindcss": "^4.0.8",
    "typescript": "~5.7.2"
  }
}
