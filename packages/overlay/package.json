{
  "name": "@nuvio/overlay",
  "version": "2.0.0",
  "description": "Nuvio overlay — dev-only visual editor for React + Vite + Next.js + Tailwind (Brand Kit, click-to-tag, apply/undo).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ehah/Nuvio.git",
    "directory": "packages/overlay"
  },
  "keywords": [
    "nuvio",
    "vite",
    "overlay",
    "devtools",
    "react"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/index.js",
    "./dist/NuvioNextShell.js",
    "./dist/style.css",
    "./dist/NuvioNextShell.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/NuvioNextShell.d.ts",
      "import": "./dist/NuvioNextShell.js"
    },
    "./style.css": "./dist/style.css"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@nuvio/shared": "workspace:*",
    "posthog-js": "^1.380.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@nuvio/ast-engine": "workspace:*",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
