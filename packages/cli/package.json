{
  "name": "@nuvio/cli",
  "version": "2.0.0",
  "description": "Nuvio CLI — Vite and Next.js onboarding and diagnostics (init, doctor, scan, stats, brand, coverage).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ehah/Nuvio.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "nuvio",
    "vite",
    "next",
    "nextjs",
    "tailwind",
    "tailwindcss",
    "react",
    "cli",
    "devtools",
    "visual-editor"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "templates",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "bin": {
    "nuvio": "./dist/cli-entry.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/cli-entry.ts --format esm --clean --external @babel/parser --external @babel/traverse --external @babel/generator --external @babel/types --external fast-glob --external @nuvio/vite-plugin --external @nuvio/shared --external @nuvio/ast-engine",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@babel/generator": "^7.26.9",
    "@babel/parser": "^7.26.9",
    "@babel/traverse": "^7.26.9",
    "@babel/types": "^7.26.9",
    "@nuvio/ast-engine": "workspace:*",
    "@nuvio/shared": "workspace:*",
    "@nuvio/vite-plugin": "workspace:*",
    "fast-glob": "^3.3.3",
    "posthog-node": "^5.36.2"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.6.8",
    "@types/babel__traverse": "^7.20.7",
    "@types/node": "^22.13.5",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
