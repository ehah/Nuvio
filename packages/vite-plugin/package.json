{
  "name": "@nuvio/vite-plugin",
  "version": "1.1.0",
  "description": "Nuvio Vite plugin 1.0 — dev WebSocket, source index, click-to-tag, secure patch writes for React + Tailwind.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ehah/Nuvio.git",
    "directory": "packages/vite-plugin"
  },
  "keywords": ["nuvio", "vite", "vite-plugin", "devtools", "react"],
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "README.md"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dev-session": {
      "types": "./dist/nuvio-dev-session.d.ts",
      "import": "./dist/nuvio-dev-session.js"
    },
    "./scan": {
      "types": "./dist/scan.d.ts",
      "import": "./dist/scan.js"
    },
    "./jsx-loc": {
      "types": "./dist/jsx-loc.d.ts",
      "import": "./dist/jsx-loc.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts src/nuvio-dev-session.ts src/scan.ts src/jsx-loc.ts --format esm --dts --clean --external vite --external @nuvio/shared --external @nuvio/ast-engine",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vite": "^5.4.0 || ^6.0.0 || ^8.0.0"
  },
  "dependencies": {
    "@babel/generator": "^7.26.9",
    "@babel/parser": "^7.26.9",
    "@babel/traverse": "^7.26.9",
    "@babel/types": "^7.26.9",
    "@nuvio/ast-engine": "workspace:*",
    "@nuvio/shared": "workspace:*",
    "fast-glob": "^3.3.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.7",
    "@types/node": "^22.13.5",
    "@types/ws": "^8.5.14",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.6"
  }
}
