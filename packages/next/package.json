{
  "name": "@nuvio/next",
  "version": "0.4.0-alpha.0",
  "description": "Nuvio Next.js dev adapter (v2) — withNuvio, custom dev server, Brand Kit, click-to-tag.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ehah/Nuvio.git",
    "directory": "packages/next"
  },
  "keywords": ["nuvio", "next", "nextjs", "devtools", "react"],
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "README.md"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./with-nuvio": {
      "types": "./dist/with-nuvio.d.ts",
      "import": "./dist/with-nuvio.js",
      "require": "./dist/with-nuvio.cjs",
      "default": "./dist/with-nuvio.js"
    },
    "./jsx-loc-loader": "./dist/jsx-loc-loader.cjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts src/with-nuvio.ts src/attach-next-server.ts src/create-next-dev-server.ts --format esm,cjs --dts --clean --external @nuvio/vite-plugin --external @nuvio/vite-plugin/dev-session --external @nuvio/vite-plugin/jsx-loc --external @nuvio/shared --external @nuvio/ast-engine --external next && cp src/jsx-loc-loader.cjs dist/jsx-loc-loader.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0"
  },
  "dependencies": {
    "@nuvio/vite-plugin": "workspace:*"
  },
  "devDependencies": {
    "@nuvio/overlay": "workspace:*",
    "@nuvio/vite-plugin": "workspace:*",
    "@types/node": "^22.13.5",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
