{
  "name": "@nuvio/shared",
  "version": "0.5.0",
  "description": "Nuvio wire protocol (Zod), shared types, and path helpers for dev tooling.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ehah/Nuvio.git",
    "directory": "packages/shared"
  },
  "keywords": ["nuvio", "vite", "devtools", "protocol"],
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "README.md"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./secure-path": {
      "types": "./dist/secure-path.d.ts",
      "import": "./dist/secure-path.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts src/secure-path.ts --format esm --dts --clean",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
